// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Document model for storing text content
model Document {
  id          Int      @id @default(autoincrement())
  content     String
  metadata    String?  // JSON string for flexible metadata
  source      String?  // Source file path or URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chunks      Chunk[]
  
  @@map("documents")
}

// Chunk model for splitting documents into smaller pieces
model Chunk {
  id          Int      @id @default(autoincrement())
  documentId  Int
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content     String
  chunkIndex  Int      // Order of chunk in document
  metadata    String?  // JSON string for chunk-specific metadata
  createdAt   DateTime @default(now())
  
  @@map("chunks")
  @@index([documentId])
}

// Collection model for organizing documents
model Collection {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("collections")
}

// Query history for tracking searches
model QueryHistory {
  id        Int      @id @default(autoincrement())
  query     String
  results   String?  // JSON string for storing results
  createdAt DateTime @default(now())
  
  @@map("query_history")
}

// Provider model for AI model providers
model Provider {
  id          Int      @id @default(autoincrement())
  name        String   @unique  // e.g., "OpenAI", "Anthropic", "Cohere", "Local"
  apiEndpoint String?  // Base API endpoint URL
  apiKeyName  String?  // Deprecated: was env var name; kept for migration compat
  apiKey      String?  // The actual API key secret (stored locally on device)
  isActive    Boolean  @default(true)
  config      String?  // JSON string for provider-specific configuration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  models      Model[]
  
  @@map("providers")
}

// Model model for AI models
model Model {
  id              Int      @id @default(autoincrement())
  providerId      Int
  provider        Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name            String   // e.g., "gpt-4", "claude-3-opus", "text-embedding-3-small"
  displayName     String?  // User-friendly name
  modelType       String   // "embedding", "chat", "completion"
  contextWindow   Int?     // Maximum context window size
  embeddingDim    Int?     // Embedding dimension (for embedding models)
  isActive        Boolean  @default(true)
  config          String?  // JSON string for model-specific configuration
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  chats           Chat[]
  
  @@map("models")
  @@unique([providerId, name])
  @@index([providerId])
  @@index([modelType])
}

// Chat/Conversation model
model Chat {
  id           Int       @id @default(autoincrement())
  title        String    // Auto-generated or user-defined
  modelId      Int
  model        Model     @relation(fields: [modelId], references: [id])
  collectionId Int?      // Optional linked knowledge base
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
  
  @@map("chats")
  @@index([modelId])
  @@index([createdAt])
}

// Message model for chat messages
model Message {
  id        Int      @id @default(autoincrement())
  chatId    Int
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String   // "user", "assistant", "system"
  content   String
  metadata  String?  // JSON string for tokens, timing, etc.
  createdAt DateTime @default(now())
  
  @@map("messages")
  @@index([chatId])
}

// Settings model for storing app preferences
model Settings {
  id             Int      @id @default(autoincrement())
  key            String   @unique  // e.g., "lastUsedModelId"
  value          String   // JSON string for flexible value storage
  updatedAt      DateTime @updatedAt
  
  @@map("settings")
}
